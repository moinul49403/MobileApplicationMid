<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== TITLE ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:text="📝 Student Grade Report"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- ===== 4. STUDENT INFO SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name: John Doe"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Student ID: STU-2025-001"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Semester: Fall 2025"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Department: Computer Science"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- ===== GRADE TABLE ===== -->
        <TableLayout
            android:id="@+id/tableLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:stretchColumns="*">

            <!-- 5. Header Row — distinct background -->
            <TableRow
                android:background="#1976D2"
                android:padding="2dp">

                <TextView
                    android:padding="10dp"
                    android:text="Subject"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Obtained"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Total"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Grade"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </TableRow>

            <!-- Subject rows & summary row added dynamically in Kotlin -->

        </TableLayout>

        <!-- ===== 8. GPA DISPLAY ===== -->
        <TextView
            android:id="@+id/tvGPA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#E8EAF6"
            android:gravity="center"
            android:padding="14dp"
            android:text="GPA: 0.00"
            android:textColor="#1976D2"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- ===== DIVIDER ===== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#BDBDBD" />

        <!-- ===== 9. ADD SUBJECT SECTION ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Add New Subject"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etSubjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="Subject Name"
            android:inputType="text"
            android:padding="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etObtained"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:hint="Obtained Marks"
                android:inputType="number"
                android:padding="12dp" />

            <EditText
                android:id="@+id/etTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:hint="Total Marks"
                android:inputType="number"
                android:padding="12dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="➕ Add Subject" />

        <!-- ===== DIVIDER ===== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#BDBDBD" />

        <!-- ===== 10. PRINT / SHARE BUTTON ===== -->
        <Button
            android:id="@+id/btnPrint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="🖨️ Print / Share Report" />

    </LinearLayout>
</ScrollView>