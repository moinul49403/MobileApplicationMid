<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/stickyToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="The Daily Reader"
            android:textColor="#212121"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnBookmark"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Bookmark article"
            android:src="@android:drawable/btn_star_big_off" />

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Share article"
            android:src="@android:drawable/ic_menu_share" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabBackToTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:contentDescription="Back to top"
        android:src="@android:drawable/arrow_up_float" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/stickyToolbar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivHeader"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="Article header image"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:layout_constraintDimensionRatio="16:9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_default="spread" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_category_tag"
                    android:text="TECHNOLOGY"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvArticleTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="The Future of AI in Mobile Development"
                    android:textColor="#212121"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:contentDescription="Author avatar"
                        android:src="@android:drawable/sym_def_app_icon" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Elena Morris"
                            android:textColor="#212121"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oct 24, 2025 - 8 min read"
                            android:textColor="#616161"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="#E0E0E0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Navigation"
                    android:textColor="#212121"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavIntro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Introduction" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavKeyPoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Key Points" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavAnalysis"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Analysis" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNavConclusion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Conclusion" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/sectionIntro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="1. Introduction"
                    android:textColor="#212121"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Artificial intelligence has steadily moved from a cloud-only capability to a practical tool that can run directly on phones. Five years ago, most mobile teams treated AI features as expensive experiments, often requiring unstable network calls and long response times. Today, the hardware story is different. Modern chipsets include dedicated neural processing units, and framework support in Android has matured enough that inference pipelines can be integrated into regular feature planning. This shift matters because users now expect contextual help, smarter search, and personalized experiences without a noticeable delay. Mobile product teams are responding by treating AI as part of the interface layer rather than an add-on service. Voice refinement, image understanding, and predictive suggestions are becoming default expectations in consumer apps. For developers, this creates both opportunity and pressure. The opportunity is to deliver richer experiences with smaller teams; the pressure is to balance model quality, battery life, and privacy in production environments." />

                <TextView
                    android:id="@+id/sectionKeyPoints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="2. Key Points"
                    android:textColor="#212121"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="The first key trend is on-device inference for everyday tasks. Developers are using lightweight transformer and vision models to support text completion, image tagging, and content moderation without sending sensitive data off-device. The second trend is hybrid execution, where smaller models handle immediate decisions locally while larger models run in the cloud for deeper reasoning when connectivity is strong. This architecture keeps performance smooth and costs predictable. Third, tooling has improved. Teams can now profile model latency in realistic user journeys, quantize models with less quality loss, and monitor drift through standard analytics pipelines. Fourth, responsible AI requirements are becoming part of app quality standards. Product managers now ask for explainability cues, fallback states, and safer prompts during design review, not after launch. Finally, collaboration is changing. Mobile engineers, data scientists, and designers increasingly ship features in the same sprint cycle, because AI behavior influences copywriting, interaction patterns, and trust signals across the entire app." />

                <TextView
                    android:id="@+id/sectionAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="3. Analysis"
                    android:textColor="#212121"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="While the momentum is undeniable, success still depends on execution discipline. AI features can fail in subtle ways that traditional QA scripts do not catch, especially when outputs vary by context or user history. Teams that perform well are adopting scenario-based testing with representative prompts and multilingual edge cases. They also define clear non-AI fallbacks so users never hit dead ends. From a business perspective, cost governance is as important as model quality. Even small per-request cloud charges can grow quickly at scale, so caching, batching, and on-device preprocessing become strategic decisions, not minor optimizations. Privacy regulations also influence architecture choices. On-device processing can reduce legal overhead, but developers still need transparent policies and consent controls when personal data informs recommendations. Another factor is design clarity. Users trust AI features more when the app shows why a suggestion appears and allows easy correction. In short, technical capability alone is insufficient; reliability, transparency, and thoughtful interface design determine whether AI feels helpful or intrusive." />

                <TextView
                    android:id="@+id/sectionConclusion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="4. Conclusion"
                    android:textColor="#212121"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="AI in mobile development is no longer a speculative trend; it is becoming a baseline capability for competitive apps. The near future will favor teams that can integrate models responsibly into real product workflows, rather than shipping isolated demos. That means aligning engineering, design, and policy decisions early. Developers should start with narrow use cases that solve clear user problems, measure outcomes carefully, and iterate based on real behavior instead of benchmark scores alone. Over time, these disciplined releases build the infrastructure and trust required for more advanced assistants and personalization layers. Platform improvements in Android, combined with stronger open-source ecosystems, make this path more accessible than ever for small and medium teams. The remaining challenge is choosing where intelligence adds value and where simple UX still wins. When teams respect that boundary, AI can elevate mobile experiences in ways that feel fast, private, and genuinely useful for everyday users." />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="#E0E0E0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tags:"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_tag"
                                android:text="Android" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_tag"
                                android:text="AI" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_tag"
                                android:text="Productivity" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_tag"
                                android:text="UX" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Related Articles"
                    android:textColor="#212121"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F5F5"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:contentDescription="Related article thumbnail"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_report_image" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="How Edge AI Is Reducing Latency in News Apps"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F5F5"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:contentDescription="Related article thumbnail"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_report_image" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Designing Transparent AI Recommendations for Mobile"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F5F5"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:contentDescription="Related article thumbnail"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_report_image" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Battery-Smart Model Deployment Strategies in 2026"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>