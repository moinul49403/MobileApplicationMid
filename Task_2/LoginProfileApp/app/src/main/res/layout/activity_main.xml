<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F7FA">

    <!-- Logo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:src="@drawable/flappycharacter"
        android:contentDescription="App Logo" />

    <!-- Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/imgLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Welcome Back!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#222222" />

    <!-- Username -->
    <EditText
        android:id="@+id/etUsername"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtTitle"
        android:layout_marginTop="24dp"
        android:hint="Username"
        android:padding="14dp"
        android:background="@android:drawable/edit_text"
        android:inputType="text" />

    <!-- Password -->
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/etUsername"
        android:layout_marginTop="14dp"
        android:hint="Password"
        android:padding="14dp"
        android:inputType="textPassword" />

    <!-- Forgot Password -->
    <TextView
        android:id="@+id/txtForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/etPassword"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="10dp"
        android:text="Forgot Password?"
        android:textColor="#2962FF"
        android:textStyle="bold" />

    <!-- Login Button -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtForgot"
        android:layout_marginTop="30dp"
        android:text="Login"
        android:backgroundTint="#2962FF"
        android:textColor="#FFFFFF" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

    <!-- Profile Card (Hidden by default) -->
    <RelativeLayout
        android:id="@+id/profileCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:padding="20dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_centerHorizontal="true"
            android:src="@drawable/avatar"
            android:contentDescription="Profile Avatar" />

        <TextView
            android:id="@+id/txtProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/imgAvatar"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="12dp"
            android:text="Profile Information"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtProfileUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtProfileTitle"
            android:layout_marginTop="20dp"
            android:text="Name: Admin User"
            android:textAlignment="center"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtProfileEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtProfileUsername"
            android:layout_marginTop="8dp"
            android:text="Email: admin@example.com"
            android:textAlignment="center"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtProfileBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtProfileEmail"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Bio: Android developer with interest in mobile UI and UX."
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtProfileBio"
            android:layout_marginTop="30dp"
            android:text="Logout"
            android:backgroundTint="#FF5252"
            android:textColor="#FFFFFF" />

    </RelativeLayout>

</RelativeLayout>